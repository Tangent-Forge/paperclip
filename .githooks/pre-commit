#!/bin/bash
# Pre-commit hook to prevent committing secrets
# Install with: git config core.hooksPath .githooks

# Patterns to detect
PATTERNS=(
    "sk-[a-zA-Z0-9]{20,}"
    "sk-ant-[a-zA-Z0-9-]{20,}"
    "AIza[a-zA-Z0-9_-]{35}"
    "github_pat_[a-zA-Z0-9_]{22,}"
    "figd_[a-zA-Z0-9_]{20,}"
    "napi_[a-zA-Z0-9_]{20,}"
    "pcp_[a-zA-Z0-9_]{20,}"
    "password\s*=\s*['\"][a-zA-Z0-9_\-]{8,}['\"]"
    "api[_-]?key\s*=\s*['\"][a-zA-Z0-9_\-]{10,}['\"]"
    "secret\s*=\s*['\"][a-zA-Z0-9_\-]{10,}['\"]"
    "token\s*=\s*['\"][a-zA-Z0-9_\-]{10,}['\"]"
)

# Files to check
FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$FILES" ]; then
    exit 0
fi

FOUND_SECRETS=0

for FILE in $FILES; do
    if [ ! -f "$FILE" ]; then
        continue
    fi

    for PATTERN in "${PATTERNS[@]}"; do
        if grep -qE "$PATTERN" "$FILE" 2>/dev/null; then
            echo "❌ ERROR: Potential secret detected in $FILE"
            echo "   Pattern: $PATTERN"
            echo "   Line(s):"
            grep -nE "$PATTERN" "$FILE" | head -5
            FOUND_SECRETS=1
        fi
    done
done

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo "🚫 COMMIT BLOCKED: Secrets detected in staged files"
    echo "   Please remove the secrets before committing"
    echo "   Use: git reset HEAD <file> to unstage files"
    exit 1
fi

exit 0
