{
  "name": "@paperclipai/mcp-server-gumroad",
  "version": "0.1.0",
  "license": "MIT",
  "description": "MCP server exposing Gumroad operations (products, sales, offer codes, webhooks) to Paperclip agents.",
  "type": "module",
  "bin": {
    "paperclip-mcp-gumroad": "./dist/stdio.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "bin": { "paperclip-mcp-gumroad": "./dist/stdio.js" },
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "dev": "node --loader ts-node/esm src/stdio.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
