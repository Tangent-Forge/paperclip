{
  "name": "@paperclipai/plugin-linear-sync",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Deterministic Linear-to-Paperclip intake sync plugin",
  "scripts": {
    "prebuild": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps",
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps && tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "keywords": ["paperclip", "plugin", "linear", "sync"],
  "author": "Paperclip",
  "license": "MIT",
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
